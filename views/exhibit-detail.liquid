{% layout 'layouts/base.liquid' %}

{% block head %}
<link
  rel="preload"
  as="image"
  href="https://fdnd-agency.directus.app/assets/{{ exhibit.cover }}?format=avif&width=1200&quality=70"
>
{% endblock %}

{% block content %}
<main>
  <section class="hero img-wrapper img-wrapper--hero">
    <svg class="spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 32 32">
      <path fill="currentColor" d="M16 12.44a3.565 3.565 0 0 1 3.566 3.566A3.565 3.565 0 0 1 16 19.572a3.565 3.565 0 0 1-3.566-3.566A3.565 3.565 0 0 1 16 12.439Zm-1.553 11.375L16 32l1.553-8.185 4.567 6.968-1.695-8.157 6.888 4.687-4.692-6.888 8.162 1.695-6.974-4.567L32 16l-8.19-1.553 6.973-4.567-8.162 1.695 4.692-6.888-6.888 4.687 1.695-8.157-4.567 6.968L16 0l-1.553 8.185L9.88 1.217l1.695 8.157-6.888-4.687 4.692 6.888L1.217 9.88l6.974 4.567L0 16l8.19 1.553-6.973 4.567 8.162-1.695-4.692 6.888 6.888-4.687-1.695 8.157 4.567-6.968Z"/>
    </svg>
    {% render 'partials/picture.liquid',
      image_src: exhibit.cover,
      alt_text: exhibit.title,
      class: 'hero-image',
      fetch_type: 'high',
      decoding_type: 'sync'
    %}
  </section>

  <article class="exhibit">
    <aside class="exhibit-sidebar">
      <section class="exhibit-intro">
        <p class="exhibit-period">{{ exhibit.period }}</p>
        <h1 class="exhibit-title">{{ exhibit.title }}</h1>
        <p class="exhibit-creator">
          {{ exhibit.creators.first.teylers_museum_persons_id.last_name }},
          {{ exhibit.creators.first.teylers_museum_persons_id.first_name }}
        </p>
        <a class="btn btn--primary exhibit-link" href="/niet-beschikbaar">Bekijk onze hele collectie</a>
      </section>

      <dl class="info-list">
        <div class="info-item">
          <dt class="info-label">Objecttype</dt>
          <dd>{{ exhibit.object_type }}</dd>
        </div>

        <div class="info-item item-list">
          <dt class="info-label">Maker(s)</dt>
          <dd>
            <ul class="creators-list">
              {% for creator in exhibit.creators %}
                <li class="creator-item">
                  <p>
                    {{ creator.teylers_museum_persons_id.last_name }},
                    {{ creator.teylers_museum_persons_id.first_name }} (
                    {{- creator.teylers_museum_persons_id.birth_year }}
                    - {{ creator.teylers_museum_persons_id.death_year }})
                  </p>
                  <p>{{ creator.teylers_museum_persons_id.roles | capitalize }}</p>
                </li>
              {% endfor %}
            </ul>
          </dd>
        </div>
      </dl>
      <button class="btn btn--secondary btn-more">Meer details</button>
      <button class="btn btn--secondary btn-less">Minder details</button>
    </aside>

    <section class="exhibit-content">
      {% if exhibit.is_on_display %}
        <p class="exhibit-status">Nu te zien in het museum</p>
      {% else %}
        <p class="exhibit-status">Momenteel niet te zien in het museum</p>
      {% endif %}

      {% for block in exhibit.content_blocks %}
        {% if block.block_type == 'paragraph' %}
          <p>{{ block.text }}</p>
        {% elsif block.block_type == 'heading' %}
          <h2>{{ block.text }}</h2>
        {% elsif block.block_type == 'quote' %}
          <blockquote>{{ block.text }}</blockquote>
        {% endif %}
      {% endfor %}
    </section>
  </article>
</main>

<section class="timeline">
  <aside class="table-of-content">
    <h3>inhoud</h3>
    <nav>
      <ol>
        {% for section in sectionsWithQuestions %}
          <li>
            <a href="#{{ section.slug }}">{{ section.title }}</a>
          </li>
        {% endfor %}
      </ol>
    </nav>
  </aside>

  <article class="timeline-article">
    {% for section in sectionsWithQuestions %}
        <section class="timeline-article-section" id="{{ section.slug }}">
            <p class="year">
            {{ section.start_year }}
            {% if section.end_year %} - {{ section.end_year }} {% endif %}
            </p>
            <h2>{{ section.title }}</h2>
            <p class="summary">{{ section.summary }}</p>

            {% if section.cover %}
            <div class="img-wrapper img-wrapper--fit">
                <svg class="spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 32 32">
                <path fill="currentColor" d="M16 12.44a3.565 3.565 0 0 1 3.566 3.566A3.565 3.565 0 0 1 16 19.572a3.565 3.565 0 0 1-3.566-3.566A3.565 3.565 0 0 1 16 12.439Zm-1.553 11.375L16 32l1.553-8.185 4.567 6.968-1.695-8.157 6.888 4.687-4.692-6.888 8.162 1.695-6.974-4.567L32 16l-8.19-1.553 6.973-4.567-8.162 1.695 4.692-6.888-6.888 4.687 1.695-8.157-4.567 6.968L16 0l-1.553 8.185L9.88 1.217l1.695 8.157-6.888-4.687 4.692 6.888L1.217 9.88l6.974 4.567L0 16l8.19 1.553-6.973 4.567 8.162-1.695-4.692 6.888 6.888-4.687-1.695 8.157 4.567-6.968Z"/>
                </svg>
                {% render 'partials/picture.liquid',
                image_src: section.cover,
                alt_text: section.title,
                width: 800,
                height: 600,
                sizes: '(max-width: 600px) 400px, 800px',
                loading_type: 'lazy'
                %}
            </div>
            <p class="source">source hier komt een bron - met jaartal</p>
            {% endif %}

            {% for block in section.content_blocks %}
            {% if block.block_type == 'paragraph' %}
                <p>{{ block.text }}</p>
            {% elsif block.block_type == 'quote' %}
                {% assign quoteText = block.text | split: '"' %}
                <blockquote>
                <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 21V14C3 9.02944 6.47715 5 11 5V7C8.23858 7 6 9.68629 6 13V14H9V21H3ZM13 21V14C13 9.02944 16.4772 5 21 5V7C18.2386 7 16 9.68629 16 13V14H19V21H13Z" fill="#FFCC00"/>
                </svg>
                <div class="quote">
                    {% if quoteText[1] %}
                    <q>{{ quoteText[1] }}</q>
                    {%- if quoteText[2] != blank -%}
                        <cite>{{ quoteText[2] | strip }}</cite>
                    {% endif %}
                    {% else %}
                    <q>{{ block.text }}</q>
                    {% endif %}
                </div>
                </blockquote>
            {% endif %}
            {% endfor %}
        </section>

        {% if section.question %}
            <section class="question-card">
                <h3>Quiz vraag</h3>
                <form action="/quiz-answer" method="POST">
                    <input type="hidden" name="exhibit_slug" value="{{ exhibit.slug }}">
                    <input type="hidden" name="exhibit_id" value="{{ exhibit.id }}">
                    <input type="hidden" name="attempt_id" value="{{ attempt_id }}">
                    <input type="hidden" name="question_id" value="{{ section.question.id }}">
                    <input type="hidden" name="section_slug" value="{{ section.slug }}">

                    <fieldset>
                        <legend>{{ section.question.question }}</legend>
                        {% for option in section.question.options %}
                        <label class="option">
                            <input type="radio" name="chosen_option" value="{{ option.key }}" class="option-input" {% if forloop.first %}required{% endif %}>
                            <span class="option-key">{{ option.key }}</span> 
                            <span class="option-answer">{{ option.answer }}</span>
                        </label>
                        {% endfor %}
                    </fieldset>
                    <button class="btn btn--primary quiz-answer-btn" type="submit">Controleer antwoord</button>
                </form>
            </section>
        {% endif %}
    {% endfor %}
    {% if attempt_id %}
        <form action="/quiz-submit" method="POST">
            <input type="hidden" name="exhibit_slug" value="{{ exhibit.slug }}">
            <input type="hidden" name="attempt_id" value="{{ attempt_id }}">
            <button type="submit">Bekijk mijn score</button>
        </form>
    {% endif %}
  </article>
</section>

{% endblock %}
